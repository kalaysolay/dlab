POSTGRES_DB=damulab
POSTGRES_USER=damulab
POSTGRES_PASSWORD=change-me

# AI: для локальной работы с ключом достаточно OPENAI_API_KEY (профиль local по умолчанию — openai).
# Явно отключить внешние вызовы: AI_PROVIDER=stub или AI_REAL_PROVIDERS_ENABLED=false
# Не копируйте AI_REAL_PROVIDERS_ENABLED=false, если хотите вызывать API.
# DeepSeek по умолчанию не используется; включить fallback: AI_FALLBACK_PROVIDER=deepseek + DEEPSEEK_API_KEY.
AI_PROVIDER=openai
AI_FALLBACK_PROVIDER=
AI_REAL_PROVIDERS_ENABLED=true
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5.2
OPENAI_MINI_LECTURE_MODEL=gpt-4o
OPENAI_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MINI_LECTURE_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
